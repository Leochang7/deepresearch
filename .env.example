# DeepResearch Agent - Environment Variables
# Copy this file to .env and fill in your values.
# .env is not committed to git.

# Config file path (optional, overrides default search order)
DEEPRESEARCH_CONFIG_PATH=

# LLM - MiMo v2.5 Pro (default)
DEEPRESEARCH_LLM_PROVIDER=mimo
DEEPRESEARCH_LLM_BASE_URL=https://api.xiaomimimo.com/v1
DEEPRESEARCH_LLM_MODEL=mimo-v2.5-pro
DEEPRESEARCH_LLM_API_KEY_HEADER=api-key
DEEPRESEARCH_LLM_API_KEY_PREFIX=
DEEPRESEARCH_LLM_API_KEY_REQUIRED=true
DEEPRESEARCH_LLM_MAX_TOKENS_FIELD=max_completion_tokens
MIMO_API_KEY=

# Embedding - Qwen3-Embedding-4B
DEEPRESEARCH_EMBEDDING_BASE_URL=
DEEPRESEARCH_EMBEDDING_API_KEY=
DEEPRESEARCH_EMBEDDING_MODEL=Qwen3-Embedding-4B
DEEPRESEARCH_EMBEDDING_DIM=2560
DEEPRESEARCH_EMBEDDING_REQUEST_DIMENSIONS=false

# Reranker - bge-reranker-v2-m3
DEEPRESEARCH_RERANKER_BASE_URL=
DEEPRESEARCH_RERANKER_API_KEY=
DEEPRESEARCH_RERANKER_MODEL=bge-reranker-v2-m3

# Report and evidence quality
DEEPRESEARCH_REPORT_PROFILE=tech_research
DEEPRESEARCH_EVIDENCE_MIN_CONFIDENCE=0.3
DEEPRESEARCH_EVIDENCE_MIN_TOKEN_OVERLAP=0.1

# Retrieval fusion
DEEPRESEARCH_RRF_K=60
DEEPRESEARCH_MAX_FUSED_DOCS=20
DEEPRESEARCH_MAX_FUSED_CHUNKS=30
DEEPRESEARCH_MMR_LAMBDA=0.7
DEEPRESEARCH_MAX_MMR_RESULTS=12

# Lexical tokenizer
DEEPRESEARCH_LEXICAL_TOKENIZER=builtin
DEEPRESEARCH_LEXICAL_LATIN_MIN_CHARS=2
DEEPRESEARCH_LEXICAL_CJK_NGRAM_FALLBACK=true
DEEPRESEARCH_LEXICAL_USERDICT_PATH=

# Milvus
DEEPRESEARCH_MILVUS_URI=http://localhost:19530
DEEPRESEARCH_MILVUS_CHUNKS_COLLECTION=deepresearch_chunks
DEEPRESEARCH_MILVUS_MEMORIES_COLLECTION=deepresearch_memories

# Search
DEEPRESEARCH_SEARCH_PROVIDER=tavily
DEEPRESEARCH_RETRIEVAL_REQUEST_CONCURRENCY=1
TAVILY_API_KEY=

# Langfuse (optional)
# Set enabled=true to report runs/evaluations to Langfuse.
# Set prompt provider to langfuse_with_local_fallback to fetch runtime prompts
# from Langfuse while keeping local prompts as offline fallback.
DEEPRESEARCH_LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
DEEPRESEARCH_EXPERIMENT_NAME=deepresearch
DEEPRESEARCH_PROMPT_PROVIDER=local
DEEPRESEARCH_PROMPT_LABEL=production

# Langfuse quick switch for runtime prompt management:
# DEEPRESEARCH_LANGFUSE_ENABLED=true
# DEEPRESEARCH_PROMPT_PROVIDER=langfuse_with_local_fallback
# DEEPRESEARCH_PROMPT_LABEL=production
